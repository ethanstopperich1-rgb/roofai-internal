# ---------- Required ----------

# Google Maps Platform — Maps JS, Places (New), Geocoding, Street View, Maps Static, Solar API
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# Optional separate server-only Google key (referer-restrict the public one,
# IP-restrict this one). Falls back to NEXT_PUBLIC_GOOGLE_MAPS_KEY if unset.
GOOGLE_SERVER_KEY=

# Anthropic — Claude vision roof analysis (/api/vision)
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Google Gemini — sales-tactics insights panel (/api/insights)
GEMINI_API_KEY=

# ATTOM Data Property API — stories, year built, lot size (/api/property)
# Free tier 250 calls/month at api.developer.attomdata.com
ATTOM_API_KEY=

# Replicate — Grounded SAM compound roof refinement (/api/sam-refine)
# ~$0.005/run, $5 free signup credit at replicate.com
REPLICATE_API_TOKEN=

# Mapbox (optional) — alternative satellite tile provider for properties
# where Google's imagery is older than 3 years. When set, the pipeline
# auto-routes to Mapbox Satellite for stale-Google-imagery properties;
# without it, every property uses Google. ~$1/1k tiles vs Google's ~$2/1k.
# Get a public token at account.mapbox.com.
MAPBOX_ACCESS_TOKEN=

# ---------- Branding (optional overrides) ----------
# Used by the PDF header, summary text, and headline — for white-labeling per client.
ROOFAI_COMPANY_NAME=
ROOFAI_PHONE=
ROOFAI_EMAIL=
ROOFAI_WEBSITE=
ROOFAI_PRIMARY_COLOR=
ROOFAI_ACCENT_COLOR=
# Set to "true" for restoration roofers — surfaces full Xactimate-style
# line items in the UI by default.
ROOFAI_SHOW_XACTIMATE=

# ---------- Phase 2 ----------
# DATABASE_URL=

# ---------- Observability (optional) ----------
# Sentry — runtime error capture (server + browser). When unset, every
# `Sentry.captureException` call is a silent no-op. Create a project at
# https://sentry.io/ — the DSN looks like `https://abc...@oXYZ.ingest.us.sentry.io/123`.
NEXT_PUBLIC_SENTRY_DSN=
# Sample rate for browser performance traces (0..1). Default 0.02 = 2%.
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=
# Server-side performance traces. Default 0.05.
SENTRY_TRACES_SAMPLE_RATE=
# Build-time source-map upload — only needed in CI / Vercel. Create a
# release-scoped token at https://sentry.io/settings/account/api/auth-tokens/
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# ---------- Health check ----------
# /api/healthz pings every dep below. Required keys cause 503 when missing.
