# =====================================================================
# Voxaris Pitch — environment variable checklist
#
# Tier the variables by what each surface needs to actually work. Set
# everything in REQUIRED before you flip production traffic on; CRITICAL
# integrations gate specific features (SMS, voice agent, dashboards);
# OPTIONAL upgrades quality or observability without blocking anything.
#
#   REQUIRED       :  /quote will render and the rep tool will load
#   CRITICAL DB    :  dashboard data persists, /p/[id] cross-device works
#   CRITICAL VOICE :  Sydney call data lands in the dashboard
#   CRITICAL SMS   :  customer SMS flow + 2-way bot work
#   OPTIONAL       :  observability, fallback providers, branding
#
# Set values inline below — each section flags its tier.
# =====================================================================


# ─── REQUIRED ──────────────────────────────────────────────────────────

# Google Maps Platform — Maps JS, Places (New), Geocoding, Street View,
# Maps Static, Solar API. Customer /quote + rep tool both depend on this.
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# Optional server-only Google key (referer-restrict the public one,
# IP-restrict this one). Falls back to NEXT_PUBLIC_GOOGLE_MAPS_KEY if unset.
GOOGLE_SERVER_KEY=

# Anthropic — Claude vision roof analysis (/api/vision)
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Roboflow — SAM3 workflow inference for the polygon pipeline.
ROBOFLOW_API_KEY=
# Override when the workflow gets republished (Roboflow assigns a new ID).
# Default points at bradens-workspace test workflow; lib/roboflow-workflow-
# config.ts is the single source of truth.
ROBOFLOW_SAM3_WORKFLOW_URL=

# Upstash Redis — rate-limit + cache + SMS conversation memory. Without
# this, lib/ratelimit.ts FAILS OPEN (no per-route abuse protection).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Staff auth — HTTP Basic gate on /, /dashboard/*, /history, /admin,
# /eval-trace, rep-only /api routes, and POST /api/proposals (proposal
# persistence from the internal estimator). Coexists with Supabase Auth
# (magic-link login at /login) — middleware accepts either source.
STAFF_AUTH_USER=
STAFF_AUTH_PASS=


# ─── CRITICAL — Supabase (dashboard, persistence, multi-tenancy) ──────

# When set, /api/leads writes to the leads table, /p/[id] reads from
# proposals (cross-device share), and /dashboard/* shows live data.
# Without these set, the dashboard renders empty states and /api/leads
# falls back to LEAD_WEBHOOK_URL only.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — bypasses RLS. Required for /api routes that have no
# authenticated user (lead capture, agent event sink, etc).
SUPABASE_SERVICE_ROLE_KEY=


# ─── CRITICAL — Sydney voice agent (when the deal needs voice data) ───

# /api/agent/events verifies inbound posts with HMAC against this secret.
# Set the SAME value on LiveKit Cloud Agent secrets so Sydney can sign.
# Generate with: openssl rand -hex 32
AGENT_EVENTS_SECRET=

# Set on LiveKit Cloud (not Vercel) — Sydney's worker reads this and
# posts call_started/tool_fired/call_ended events here. Vercel doesn't
# need to know about it.
# AGENT_EVENTS_URL=https://pitch.voxaris.io/api/agent/events


# ─── CRITICAL — Twilio (customer SMS confirmation + 2-way bot) ────────

# When set, /api/leads fires a confirmation SMS after every submit. When
# the customer replies, /api/sms/inbound uses the same credentials to
# send AI replies.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# E.164. Must be A2P 10DLC registered (or toll-free verified) before
# production traffic — US carriers block unverified senders.
TWILIO_PHONE_NUMBER=
# Only set when the SMS webhook is behind ngrok or a proxy rewriting
# Host; production usually doesn't need this.
TWILIO_WEBHOOK_URL_OVERRIDE=


# ─── OPTIONAL — Observability, fallbacks, branding ────────────────────

# Sentry — runtime error capture (server + browser). When unset, every
# Sentry.captureException is a silent no-op. Create a project at
# https://sentry.io/ — DSN looks like `https://abc...@oXYZ.ingest.us.sentry.io/123`.
NEXT_PUBLIC_SENTRY_DSN=
# Sample rate for browser performance traces (0..1). Default 0.02 = 2%.
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=
# Server-side performance traces. Default 0.05.
SENTRY_TRACES_SAMPLE_RATE=
# Build-time source-map upload — only needed in CI / Vercel.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# /api/healthz token gate. When set, only requests carrying
# ?token=<value> (or X-Healthz-Token header) see the full per-component
# breakdown. Unauth callers get a slim {status, timestamp}. Backward-
# compat: leave unset to keep the route fully public (matches the
# pre-2026-05-12 behavior).
HEALTHZ_TOKEN=

# Google Gemini — sales-tactics insights panel (/api/insights)
GEMINI_API_KEY=

# ATTOM Data Property API — stories, year built, lot size (/api/property)
# Free tier 250 calls/month at api.developer.attomdata.com
ATTOM_API_KEY=

# Replicate — Grounded SAM compound roof refinement (/api/sam-refine)
# ~$0.005/run, $5 free signup credit at replicate.com
REPLICATE_API_TOKEN=

# Mapbox (optional) — alternative satellite tile provider for properties
# where Google's imagery is older than 3 years. When set, the pipeline
# auto-routes to Mapbox Satellite for stale-Google-imagery properties.
# Get a public token at account.mapbox.com.
MAPBOX_ACCESS_TOKEN=

# Optional CRM/Slack/email destination for new leads. /api/leads POSTs
# the full lead payload here AFTER writing to Supabase. Common values:
# Make.com / Zapier / Slack webhook URL.
LEAD_WEBHOOK_URL=


# ─── White-label branding overrides (per-deploy) ──────────────────────

ROOFAI_COMPANY_NAME=
ROOFAI_PHONE=
ROOFAI_EMAIL=
ROOFAI_WEBSITE=
ROOFAI_PRIMARY_COLOR=
ROOFAI_ACCENT_COLOR=
# Set to "true" for restoration roofers — surfaces full Xactimate-style
# line items in the UI by default.
ROOFAI_SHOW_XACTIMATE=
