node_modules
.next
.env
.env.local
*.tsbuildinfo
next-env.d.ts
.DS_Store
gcloud-mcp/
/tmp/
.vercel

# Python — agents/sydney is a Python LiveKit worker, plus the scripts/
# folder has Python ingest tooling (ingest_mrms.py). Keep bytecode +
# venv + pytest cache out of git globally so we never re-commit them
# from a subtree.
__pycache__/
*.py[cod]
.pytest_cache/
.venv/
venv/
*.egg-info/

# Local eval artifacts — generated by scripts/eval-roboflow.ts. Large
# binary overlays and tile dumps don't belong in git.
scripts/eval-output/

# Hand-traced ground truth polygons — generated locally per engineer via
# the /eval-trace UI. These contain real residential addresses and stay
# out of source control by default. Commit specific truth files manually
# (`git add -f`) if you want shared regression coverage on them.
scripts/eval-truth/*.json

# Active-learning rep-edit captures. Auto-saved by /api/eval-truth/edit-
# capture every time a rep manually corrects an AI polygon. Real customer
# addresses; per-engineer / per-deployment data. In production these go
# to Vercel Blob, not the filesystem.
scripts/eval-truth/edits/

# Throwaway diagnostic scripts from one-off bug hunts.
scripts/debug-*

# Local backups of secret files (created by scripts/fix-env-quotes.py).
.env.local.backup-*

# Per-developer Claude Code launch configs
.claude/

# Playwright MCP debug artifacts — local walk-through traces / screenshots
.playwright-mcp/
quote-step*.png
quote-step*.jpeg
quote-form-*.png
quote-form-*.jpeg
embed-*.png
embed-*.jpeg
internal-*.png
internal-*.jpeg
mobile-*.png
mobile-*.jpeg
step*-fixed.*

# Build-time data extraction cache (the 890MB raw TN building footprint
# file from microsoft.com — output goes in public/data/ which IS committed)
.cache/
.env*.local
