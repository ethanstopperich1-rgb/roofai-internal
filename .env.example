# .env.example
# Copy to .env.local and fill in the secrets for your environment.
# Vercel deployment env reads from Vercel Project Settings, not this file.

# ---- Core ------------------------------------------------------------------

# Anthropic Claude (vision + supplement + voice-notes + Tier B roof-inspector)
ANTHROPIC_API_KEY=

# Google Maps Platform (geocoding + Solar API + 3D Tiles)
GOOGLE_MAPS_API_KEY=

# Supabase (proposals, dashboard, auth)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---- Caching / Rate-limiting -----------------------------------------------

# Upstash Redis (cache + ratelimit). Either pair works.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# ---- Sentry (optional) -----------------------------------------------------

SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ---- Tier B — Multiview Roof Inspector -------------------------------------

# Flip to "1" to enable Tier B oblique refinement on /internal estimates.
# Default off — env-gated rollout per docs/superpowers/tier-b-a-decisions.md.
# Cost: ~$0.03-0.05 per refined estimate (cached 1h).
ENABLE_TIER_B_REFINEMENT=

# ---- Tier A — LiDAR Python service (Modal) ---------------------------------

# Set after deploying services/roof-lidar/ to Modal. See the README there
# for deploy instructions. When unset, the pipeline silently skips Tier A
# and falls through to Tier B/C.
LIDAR_SERVICE_URL=

# Modal CLI credentials. Only needed when deploying / interacting with
# Modal from CI. Not required at runtime by the Next.js app.
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
