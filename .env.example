# .env.example
# Copy to .env.local and fill in the secrets for your environment.
# Vercel deployment env reads from Vercel Project Settings, not this file.

# ---- Core ------------------------------------------------------------------

# Anthropic Claude (vision + supplement + voice-notes + Tier B roof-inspector)
ANTHROPIC_API_KEY=

# Google Maps Platform (geocoding + Solar API + 3D Tiles)
GOOGLE_MAPS_API_KEY=

# Supabase (proposals, dashboard, auth)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---- Caching / Rate-limiting -----------------------------------------------

# Upstash Redis (cache + ratelimit). Either pair works.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# ---- Sentry (optional) -----------------------------------------------------

SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ---- Tier B — Multiview Roof Inspector -------------------------------------

# Flip to "1" to enable Tier B oblique refinement on /internal estimates.
# Default off — env-gated rollout per docs/superpowers/tier-b-a-decisions.md.
# Cost: ~$0.03-0.05 per refined estimate (cached 1h).
ENABLE_TIER_B_REFINEMENT=

# ---- Tier A — LiDAR Python service (Modal) ---------------------------------

# Set after deploying services/roof-lidar/ to Modal. See the README there
# for deploy instructions. When unset, the pipeline silently skips Tier A
# and falls through to Tier B/C.
LIDAR_SERVICE_URL=

# Override default 30s Tier A fetch timeout. Useful for Modal cold-starts
# (~60s) or alternate hosts (Fly/Railway). Clamped to [5000, 120000] ms.
LIDAR_FETCH_TIMEOUT_MS=

# Modal CLI credentials. Only needed when deploying / interacting with
# Modal from CI. Not required at runtime by the Next.js app.
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# ---- Google Solar API — optional extras -----------------------------------

# Flip to "1" to request `additionalInsights=DETECTED_ARRAYS` on every
# buildingInsights:findClosest call. When Google has detected existing
# rooftop PV on the building, the response includes a `detectedArrays`
# block (status + latest capture date) which surfaces in the rep UI as
# an "Existing PV" chip. No extra Solar API cost; adds payload bytes.
SOLAR_DETECTED_ARRAYS=

# Set to "0" to DISABLE the Solar dataLayers binary-mask outline fetch
# inside the Tier C pipeline. Default behavior (any other value or
# unset): mask runs in parallel with findClosest; when it returns a
# valid roof component, the tight pixel-accurate polygon overrides the
# loose findClosest bbox-union outline rendered on map + 3D viewer.
# Per-facet pitch / area math is unchanged either way. Disable only if
# the mask is causing latency / payload regressions on a specific
# deployment.
SOLAR_MASK_OUTLINE=

# ---- Customer quote wizard (/quote) ---------------------------------------

# SAM3 quality gate. Default ON: when /quote's SAM3 result looks suspect
# (area >30% off from Solar findClosest, OR ≤5 vertices on a ≥3-facet
# building, OR server-side fallback source), eagerly fetch the Solar
# dataLayers mask and prefer it for the customer overlay. Costs ~$0.075
# per gate trigger; saves customer-visible "loose blue trace" failures.
# Set to "0" to disable the gate and keep SAM3 unconditionally on success.
# NEXT_PUBLIC_ since the gate runs in the customer browser.
NEXT_PUBLIC_QUOTE_SAM3_MASK_QUALITY_GATE=
